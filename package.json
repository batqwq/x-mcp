{
  "name": "x-post-mcp-server",
  "version": "0.1.0",
  "description": "Read-only MCP server for reading X/Twitter posts through TwitterAPI.io and GetXAPI.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/batqwq/x-mcp.git"
  },
  "homepage": "https://github.com/batqwq/x-mcp#readme",
  "bugs": {
    "url": "https://github.com/batqwq/x-mcp/issues"
  },
  "keywords": [
    "mcp",
    "x",
    "twitter",
    "twitterapi.io",
    "getxapi",
    "llm"
  ],
  "files": [
    "dist",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "x-post-mcp": "dist/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "server": "node dist/index.js --server",
    "tui": "node dist/index.js --tui",
    "presmoke": "npm run build",
    "smoke": "node dist/index.js --smoke",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
